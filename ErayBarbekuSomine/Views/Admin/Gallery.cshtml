@model IEnumerable<ErayBarbekuSomine.Models.Image>
@{
    ViewData["Title"] = "Medya Galerisi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    var categories = Model.Select(m => m.Category).Distinct().ToList();
}

<div class="row">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Tüm Medya Galerisi</h2>
            <button class="btn btn-danger shadow-sm d-none" id="btnBulkDelete" onclick="bulkDelete()">
                <i class="fas fa-trash-alt me-2"></i> Seçilenleri Sil (<span id="selectedCount">0</span>)
            </button>
        </div>

        <!-- Tabs -->
        <ul class="nav nav-tabs nav-line-tabs mb-5 fs-6" id="myTab" role="tablist">
            <li class="nav-item" role="presentation">
                <a class="nav-link active" id="all-tab" data-bs-toggle="tab" href="#tab-all" role="tab" aria-controls="tab-all" aria-selected="true">
                    Tümü <span class="badge bg-secondary ms-2">@Model.Count()</span>
                </a>
            </li>
            @foreach (var cat in categories)
            {
                var count = Model.Count(m => m.Category == cat);
                var catId = "tab-" + cat.ToLower();
                <li class="nav-item" role="presentation">
                    <a class="nav-link" id="@catId-header" data-bs-toggle="tab" href="#@catId" role="tab" aria-controls="@catId" aria-selected="false">
                        @cat <span class="badge bg-secondary ms-2">@count</span>
                    </a>
                </li>
            }
        </ul>

        <!-- Tab Content -->
        <div class="tab-content" id="myTabContent">
            
            <!-- All Images Tab -->
            <div class="tab-pane fade show active" id="tab-all" role="tabpanel" aria-labelledby="all-tab">
                <div class="row g-4">
                    @foreach(var img in Model) {
                        <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12" id="grid-img-@img.Id">
                            <div class="card h-100 shadow-sm border-0 position-relative">
                                
                                <!-- Checkbox for Bulk Delete -->
                                <div class="position-absolute" style="top:10px; left:10px; z-index:10">
                                    <div class="form-check">
                                        <input class="form-check-input img-checkbox" type="checkbox" value="@img.Id" style="width:20px; height:20px; cursor:pointer;" onchange="updateSelectedCount()">
                                    </div>
                                </div>

                                <div class="position-absolute" style="top:10px; right:10px; z-index:9">
                                    <button onclick="setCover(@img.Id)" class="btn btn-info btn-sm p-2 shadow text-white" title="Vitrin Yap (Kapak Fotoğrafı)">
                                        <i class="fas fa-star"></i>
                                    </button>
                                    <button onclick="document.getElementById('edit-@img.Id').click()" class="btn btn-warning btn-sm p-2 shadow" title="Değiştir">
                                        <i class="fas fa-sync-alt"></i>
                                    </button>
                                    <button onclick="deleteImageGlobal(@img.Id)" class="btn btn-danger btn-sm p-2 shadow" title="Sil">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                    <input type="file" id="edit-@img.Id" style="display:none;" accept="image/*" onchange="replaceImageGlobal(this, @img.Id, '@img.Category')" />
                                </div>
                                
                                <img src="@img.FilePath" id="src-@img.Id" class="card-img-top" alt="@img.FileName" style="height: 200px; object-fit: cover;">
                                <div class="card-body p-3">
                                    <p class="card-text text-muted mb-1" style="font-size:0.8rem;"><i class="fas fa-folder me-1"></i> @img.Category</p>
                                    <p class="card-text text-muted" style="font-size:0.8rem;"><i class="fas fa-clock me-1"></i> @img.UploadDate.ToString("dd MMM yyyy HH:mm")</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Category Tabs -->
            @foreach (var cat in categories)
            {
                var catId = "tab-" + cat.ToLower();
                <div class="tab-pane fade" id="@catId" role="tabpanel" aria-labelledby="@catId-header">
                    <div class="row g-4">
                        @foreach(var img in Model.Where(m => m.Category == cat)) {
                            <div class="col-xl-3 col-lg-4 col-md-6 col-sm-12" id="grid-img-@catId-@img.Id">
                                <div class="card h-100 shadow-sm border-0 position-relative">
                                    <div class="position-absolute" style="top:10px; right:10px; z-index:9">
                                        <button onclick="setCover(@img.Id)" class="btn btn-info btn-sm p-2 shadow text-white" title="Vitrin Yap (Kapak Fotoğrafı)">
                                            <i class="fas fa-star"></i>
                                        </button>
                                        <button onclick="document.getElementById('edit-@catId-@img.Id').click()" class="btn btn-warning btn-sm p-2 shadow" title="Değiştir">
                                            <i class="fas fa-sync-alt"></i>
                                        </button>
                                        <button onclick="deleteImageGlobal(@img.Id)" class="btn btn-danger btn-sm p-2 shadow" title="Sil">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                        <input type="file" id="edit-@catId-@img.Id" style="display:none;" accept="image/*" onchange="replaceImageGlobal(this, @img.Id, '@img.Category')" />
                                    </div>
                                    <img src="@img.FilePath" id="src-@catId-@img.Id" class="card-img-top" alt="@img.FileName" style="height: 200px; object-fit: cover;">
                                    <div class="card-body p-3">
                                        <p class="card-text text-muted mb-1" style="font-size:0.8rem;"><i class="fas fa-folder me-1"></i> @img.Category</p>
                                        <p class="card-text text-muted" style="font-size:0.8rem;"><i class="fas fa-clock me-1"></i> @img.UploadDate.ToString("dd MMM yyyy HH:mm")</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function getAntiforgeryToken() {
            return document.querySelector('input[name="__RequestVerificationToken"]').value;
        }

        function updateSelectedCount() {
            var selected = document.querySelectorAll('.img-checkbox:checked').length;
            var btn = document.getElementById('btnBulkDelete');
            var span = document.getElementById('selectedCount');
            
            span.textContent = selected;
            if(selected > 0) {
                btn.classList.remove('d-none');
            } else {
                btn.classList.add('d-none');
            }
        }

        function bulkDelete() {
            var selectedCheckboxes = document.querySelectorAll('.img-checkbox:checked');
            if(selectedCheckboxes.length === 0) return;

            var ids = Array.from(selectedCheckboxes).map(cb => parseInt(cb.value));

            Swal.fire({
                title: 'Toplu Silme', text: ids.length + " adet resmi kalıcı olarak silmek istediğinize emin misiniz?", icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#d33', confirmButtonText: 'Evet, Hepsini Sil!', cancelButtonText: 'İptal'
            }).then((result) => {
                if (result.isConfirmed) {
                    var formData = new FormData();
                    ids.forEach(id => formData.append("ids", id));
                    formData.append("__RequestVerificationToken", getAntiforgeryToken());

                    Swal.fire({ title: 'Siliniyor...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

                    fetch('/Admin/BulkDeleteImages', { method: 'POST', body: formData })
                    .then(r => r.json())
                    .then(res => {
                        if (res.success) {
                            Swal.fire('Silindi!', 'Seçilen resimler başarıyla silindi.', 'success').then(() => {
                                location.reload();
                            });
                        } else {
                            Swal.fire('Hata', res.message, 'error');
                        }
                    }).catch(() => Swal.fire('Hata', 'Sunucu hatası.', 'error'));
                }
            });
        }

        function setCover(id) {
            Swal.fire({
                title: 'Vitrin Yapılsın mı?', text: "Bu resim, ilgili kategorinin ana sayfa vitrin fotoğrafı olsun mu?", icon: 'question',
                showCancelButton: true, confirmButtonColor: '#3085d6', confirmButtonText: 'Evet, Vitrin Yap', cancelButtonText: 'İptal'
            }).then((result) => {
                if (result.isConfirmed) {
                    var formData = new FormData();
                    formData.append("id", id);
                    formData.append("__RequestVerificationToken", getAntiforgeryToken());

                    Swal.fire({ title: 'Ayarlanıyor...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

                    fetch('/Admin/SetCategoryCover', { method: 'POST', body: formData })
                    .then(r => r.json())
                    .then(res => {
                        if (res.success) {
                            Swal.fire('Başarılı!', 'Bu resim artık kategorinin vitrin fotoğrafı!', 'success');
                            // optionally reload page to accurately update visual ordering/timestamps
                        } else {
                            Swal.fire('Hata', res.message, 'error');
                        }
                    }).catch(() => Swal.fire('Hata', 'Sunucu hatası.', 'error'));
                }
            });
        }


        function replaceImageGlobal(input, id, category) {
            if (!input.files || input.files.length === 0) return;
            var file = input.files[0];
            var formData = new FormData();
            formData.append("id", id);
            formData.append("file", file);
            formData.append("category", category);
            formData.append("__RequestVerificationToken", getAntiforgeryToken());

            Swal.fire({ title: 'Değiştiriliyor...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

            fetch('/Admin/ReplaceImage', { method: 'POST', body: formData })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    var newUrl = res.newUrl + '?t=' + new Date().getTime();
                    var imgAll = document.getElementById('src-' + id);
                    if (imgAll) imgAll.src = newUrl;
                    
                    var imgCat = document.getElementById('src-tab-' + category.toLowerCase() + '-' + id);
                    if (imgCat) imgCat.src = newUrl;

                    Swal.fire('Başarılı', 'Resim başarıyla değiştirildi!', 'success');
                } else {
                    Swal.fire('Hata', res.message, 'error');
                }
            }).catch(() => Swal.fire('Hata', 'Sunucu hatası.', 'error'));
            input.value = "";
        }

        function deleteImageGlobal(id) {
            Swal.fire({
                title: 'Emin misiniz?', text: "Bu resim kalıcı olarak silinecek.", icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#d33', confirmButtonText: 'Evet, Sil!', cancelButtonText: 'İptal'
            }).then((result) => {
                if (result.isConfirmed) {
                    var formData = new FormData();
                    formData.append("id", id);
                    formData.append("__RequestVerificationToken", getAntiforgeryToken());

                    fetch('/Admin/DeleteImage', { method: 'POST', body: formData })
                    .then(r => r.json())
                    .then(res => {
                        if (res.success) {
                            var el1 = document.getElementById("grid-img-" + id);
                            if (el1) el1.remove();

                            var allEls = document.querySelectorAll('[id$="-' + id + '"]');
                            allEls.forEach(el => {
                                if (el.id.startsWith("grid-img-")) el.remove();
                            });

                            Swal.fire('Silindi!', 'Resim silindi.', 'success');
                            setTimeout(() => location.reload(), 1000);
                        } else {
                            Swal.fire('Hata', res.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
