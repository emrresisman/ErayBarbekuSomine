@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var imageCount = ViewBag.ImageCount ?? 0;
    var msgCount = ViewBag.UnreadCount ?? 0;
}

<div class="page-header">
    <div>
        <h1><i class="fas fa-gauge-high me-2" style="color:var(--admin-red)"></i>Dashboard</h1>
        <p>Hoşgeldiniz, yönetim panelinize genel bakış.</p>
    </div>
    <a href="/Admin/Upload" class="btn-admin-primary btn d-flex align-items-center gap-2">
        <i class="fas fa-cloud-arrow-up fa-sm"></i> Resim Yükle
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <a href="/Admin/Gallery" class="text-decoration-none">
            <div class="stat-card">
                <div class="stat-icon red"><i class="fas fa-images"></i></div>
                <div>
                    <div class="stat-label">Toplam Resim</div>
                    <div class="stat-value">@imageCount</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <a href="/Admin/Messages" class="text-decoration-none">
            <div class="stat-card">
                <div class="stat-icon gold"><i class="fas fa-inbox"></i></div>
                <div>
                    <div class="stat-label">Gelen Mesajlar</div>
                    <div class="stat-value">—</div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-layer-group"></i></div>
            <div>
                <div class="stat-label">Kategori Sayısı</div>
                <div class="stat-value">7</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-circle-check"></i></div>
            <div>
                <div class="stat-label">Sistem Durumu</div>
                <div class="stat-value" style="font-size:1.1rem; color:var(--admin-gold);">Aktif</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-bolt-lightning header-icon"></i> Hızlı Erişim
            </div>
            <div class="card-body">
                <div class="d-flex flex-column gap-2">
                    <a href="/Admin/Gallery" class="btn-admin-primary btn d-flex align-items-center gap-2 justify-content-center">
                        <i class="fas fa-images fa-sm"></i> Galeri Yönetimi
                    </a>
                    <a href="/Admin/Upload" class="btn btn-outline-secondary d-flex align-items-center gap-2 justify-content-center" style="border-color:var(--admin-border); color:var(--admin-text-muted);">
                        <i class="fas fa-cloud-arrow-up fa-sm"></i> Yeni Resim Yükle
                    </a>
                    <a href="/Admin/Messages" class="btn btn-outline-secondary d-flex align-items-center gap-2 justify-content-center" style="border-color:var(--admin-border); color:var(--admin-text-muted);">
                        <i class="fas fa-inbox fa-sm"></i> Gelen Mesajları Gör
                    </a>
                    <a href="/" target="_blank" class="btn btn-outline-secondary d-flex align-items-center gap-2 justify-content-center" style="border-color:var(--admin-border); color:var(--admin-text-muted);">
                        <i class="fas fa-arrow-up-right-from-square fa-sm"></i> Siteyi Aç
                    </a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <i class="fas fa-circle-info header-icon"></i> Bilgi
            </div>
            <div class="card-body">
                <p style="color:var(--admin-text-muted); font-size:0.88rem; line-height:1.7;">
                    Eray Barbekü Şömine yönetim paneline hoşgeldiniz.<br><br>
                    Sol menüden <strong style="color:var(--admin-text)">Medya Galerisi</strong>'ne giderek ürün sayfalarındaki fotoğrafları yönetebilir,
                    <strong style="color:var(--admin-text)">Gelen Mesajlar</strong>'dan müşterilerinizin iletişim formundan gönderdiği mesajları okuyabilirsiniz.
                </p>
            </div>
        </div>
    </div>
</div>
