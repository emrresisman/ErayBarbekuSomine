				@if (isAdmin)
{
    @Html.AntiForgeryToken()
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function updateCover(input, category) {
            if (!input.files || input.files.length === 0) return;
            var file = input.files[0];
            var formData = new FormData();
            formData.append("file", file);
            formData.append("category", category);
            formData.append("__RequestVerificationToken", document.querySelector('input[name="__RequestVerificationToken"]').value);

            Swal.fire({ title: 'Güncelleniyor...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });

            fetch('/Admin/UpdateCategoryCover', {
                method: 'POST',
                body: formData
            })
            .then(r => r.json())
            .then(res => {
                if (res.success) {
                    document.getElementById('cover-img-' + category).src = res.newUrl + '?t=' + new Date().getTime();
                    Swal.fire('Başarılı', 'Vitrin resmi başarıyla değiştirildi!', 'success');
                } else {
                    Swal.fire('Hata', res.message, 'error');
                }
            })
            .catch(() => Swal.fire('Hata', 'Sunucu hatası.', 'error'));
            
            input.value = "";
        }
    </script>
}
<!-- Contact Form JS -->
@if(!isAdmin) {
    <!-- We still need SweetAlert for guests interacting with the contact form -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
}
<script>
    function submitContactForm(e) {
        e.preventDefault();
        let formData = new FormData(document.getElementById('contactForm'));
        Swal.fire({ title: 'Gönderiliyor...', allowOutsideClick: false, didOpen: () => { Swal.showLoading(); } });
        fetch('/Home/SubmitContactMessage', {
            method: 'POST',
            body: formData
        })
        .then(r => r.json())
        .then(res => {
            if (res.success) {
                Swal.fire('Başarılı!', res.message, 'success');
                document.getElementById('contactForm').reset();
            } else {
                Swal.fire('Hata!', res.message, 'error');
            }
        })
        .catch(() => Swal.fire('Hata!', 'Sunucu ile iletişim kurulamadı.', 'error'));
    }
</script>
